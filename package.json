{
  "name": "agents-dashboard",
  "version": "0.1.0",
  "description": "Local web dashboard for ccusage: pick a coding-agent tool and date range, runs ccusage, renders an aggregated usage dashboard.",
  "type": "module",
  "license": "MIT",
  "author": "Danilo Giacomi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danilogiacomi/agents-dashboard.git"
  },
  "homepage": "https://github.com/danilogiacomi/agents-dashboard#readme",
  "bugs": "https://github.com/danilogiacomi/agents-dashboard/issues",
  "keywords": ["ccusage", "claude-code", "codex", "dashboard", "usage", "bun"],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "agents-dashboard": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "NODE_ENV=production bun run src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.6.0",
    "@types/bun": "latest"
  }
}
